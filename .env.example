# SourceDeck API — example environment.
# Copy to .env (or wire secrets into Code Engine / k8s Secret / OpenShift)
# and never commit real values.

# ───── Core ─────
APP_ENV=development
APP_BASE_URL=http://localhost:8080
PORT=8080
LOG_LEVEL=info

# ───── Auth ─────
DATABASE_URL=
SESSION_SECRET=
JWT_SECRET=

AUTH_PROVIDER=local            # local | oidc | ibm_iam
AUTH_ISSUER_URL=
AUTH_AUDIENCE=                 # required for oidc — the API's audience claim
AUTH_JWKS_URL=                 # defaults to <AUTH_ISSUER_URL>/.well-known/jwks.json
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=

# Escape hatches — leave unset in production unless you know what you're doing.
ALLOW_IN_MEMORY_PROD=false     # if true, lets prod boot with in-memory persistence/BYOK
ALLOW_DEV_HEADERS_PROD=false   # if true, lets prod accept x-user-* headers (dev shim)

# ───── Provider selection ─────
STORAGE_PROVIDER=local         # local | ibm_cos
AI_PROVIDER=watsonx            # mock | watsonx (default core provider)
AI_DEFAULT_PROVIDER=watsonx    # always watsonx unless explicitly changed
AI_ENABLE_BYOK=false           # tenant admins can enable per-workspace; default off
AI_ALLOWED_DRAFTING_PROVIDERS=watsonx,openai,anthropic,google

# ───── Uploads ─────
MAX_UPLOAD_MB=25
ALLOWED_UPLOAD_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain,text/csv

# ───── IBM Cloud (deployment) ─────
IBM_CLOUD_API_KEY=
IBM_CLOUD_REGION=us-east
IBM_RESOURCE_GROUP=
IBM_CODE_ENGINE_PROJECT=
IBM_CODE_ENGINE_APP_NAME=sourcedeck-api

# ───── IBM Cloud Object Storage ─────
IBM_COS_ENDPOINT=
IBM_COS_BUCKET=
IBM_COS_INSTANCE_CRN=
IBM_COS_API_KEY=
IBM_COS_SERVICE_INSTANCE_ID=

# ───── IBM watsonx.ai (default/core provider) ─────
WATSONX_API_KEY=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=
WATSONX_SPACE_ID=
WATSONX_MODEL_ID=ibm/granite-13b-chat-v2

# ───── Optional providers (NOT default — only for approved drafting workflows) ─────
# Leave blank to keep disabled. Setting a key alone does NOT enable the
# provider for governed workflows; tenant policy controls drafting access.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-1.5-pro-latest

# ───── Custom future provider (placeholder; security-review required) ─────
CUSTOM_AI_ENDPOINT=
CUSTOM_AI_API_KEY=
CUSTOM_AI_MODEL=

# ───── IBM Cloud Secrets Manager (BYOK external store) ─────
# Required to enable BYOK in production. See docs/BYOK_SECRETS_MANAGER.md
# for the activation checklist. When unset, the in-memory dev BYOK store
# refuses to serve when APP_ENV=production.
IBM_SECRETS_MANAGER_URL=
IBM_SECRETS_MANAGER_API_KEY=
IBM_SECRETS_MANAGER_INSTANCE_ID=

# ───── watsonx.governance ─────
GOVERNANCE_ENABLED=false
GOVERNANCE_PROJECT_ID=
GOVERNANCE_POLICY_SET_ID=
